flowchart TB
    User["👤 Felhasználó<br/>(böngésző)"]

    subgraph Vercel ["☁️ Vercel (cloud platform)"]
        subgraph Frontend ["Frontend — React 18 + Vite"]
            App["App komponens<br/>+ Router"]
            Pages["Oldalak<br/>(Public, Login, Dashboard,<br/>Centers, Map, Reservations…)"]
            Components["Komponensek<br/>(Layout, ReservationModal,<br/>StatCard, InteractiveMap…)"]
            Hooks["Egyéni hookok<br/>(TanStack Query alapon)<br/>useShoppingCenters,<br/>useReservations…"]
            i18n["i18n + téma<br/>(HU/EN, light/dark)"]
        end

        subgraph Backend ["Backend — Express + TypeScript"]
            API["REST API<br/>/api/auth /api/centers<br/>/api/reservations<br/>/api/dashboard /api/areas"]
            AuthMW["JWT auth middleware<br/>+ Zod validáció"]
            Sim["IoT szimulátor<br/>(setInterval 30s)"]
        end

        DB[("💾 SQLite<br/>better-sqlite3<br/>6 tábla<br/>(users, shopping_centers,<br/>parking_spaces, areas,<br/>reservations,<br/>occupancy_history)")]
    end

    User -- "HTTPS" --> App
    App --> Pages
    Pages --> Components
    Pages --> Hooks
    Hooks -- "axios HTTP" --> API
    API --> AuthMW
    AuthMW --> DB
    Sim -- "minden 30s<br/>foglaltság-frissítés" --> DB

    classDef frontendClass fill:#e3f2fd,stroke:#1976d2,stroke-width:1px
